# Copy to .env on your Oracle Cloud VM (never commit .env)
# See DEPLOY.md for full setup instructions.

# ── Public URL (DuckDNS) ──
DUCKDNS_DOMAIN=ssies-schedule.duckdns.org

# ── Supabase (Project Settings → API) ──
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret

# ── Database (pooler, port 6543) ──
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require

# ── Superadmin (must exist in Supabase Auth) ──
SUPERADMIN_EMAIL=you@example.com

# ── App secrets ──
# IMPORTANT: reuse APP_ENCRYPTION_KEY from local dev if you already have encrypted data in Supabase
APP_ENCRYPTION_KEY=PASTE_FERNET_KEY_HERE
APP_SECRET_KEY=PASTE_RANDOM_SECRET_HERE

# WAHA (same key in Docker and superadmin settings) ──
WAHA_API_KEY=PASTE_STRONG_RANDOM_KEY_HERE

# ── DuckDNS (optional cron — see docker/duckdns-update.sh) ──
DUCKDNS_TOKEN=your_duckdns_token

# ── Flask (defaults for docker-compose.prod.yml) ──
PORT=5000
USE_WAITRESS=1
FORCE_HTTPS=1
DOCKER=1
